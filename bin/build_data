#!/usr/bin/env ruby

# Builds html/data.json for the Northwestern OA/TA Finder from a local,
# version-controlled CSV (data/northwestern-agreements.csv).
#
# This replaces the upstream Google-Sheets dependency in bin/update with a
# reproducible, offline pipeline. The output shape is identical to what the
# front-end (html/js/script.js) expects:
#
#   { "header": [...8 columns...], "version": "...", "data": [ [ ...8 cells... ], ... ] }
#
# Each row is a positional array of 8 strings; empty cells become null. The
# eISSN and eISSN Link columns are allowed to be null.
#
# Usage: ruby bin/build_data        (run from the repo root)

require "csv"
require "json"

CSV_FILE  = File.join(__dir__, "..", "data", "northwestern-agreements.csv")
JSON_FILE = File.join(__dir__, "..", "html", "data.json")

HEADER = [
  "Publisher",
  "Journal Title",
  "eISSN",
  "eISSN Link",
  "Link to Agreement Info",
]

# Columns that are allowed to be blank/null in the output.
NULL_ALLOWED = ["eISSN", "eISSN Link", "Link to Agreement Info"]

def abort_with(message)
  warn "build_data: #{message}"
  exit 1
end

rows = CSV.read(CSV_FILE, headers: true)

# Validate the header matches exactly (order included).
unless rows.headers == HEADER
  abort_with("CSV header mismatch.\n  expected: #{HEADER.inspect}\n  got:      #{rows.headers.inspect}")
end

data = []
rows.each_with_index do |row, i|
  cells = HEADER.map { |col| v = row[col]; v.nil? || v.strip.empty? ? nil : v.strip }

  # Required columns must be present.
  HEADER.each_with_index do |col, idx|
    next if NULL_ALLOWED.include?(col)
    if cells[idx].nil?
      abort_with("row #{i + 2}: required column '#{col}' is blank")
    end
  end

  data << cells
end

abort_with("no data rows found in #{CSV_FILE}") if data.empty?

output = {
  "header"  => HEADER,
  "version" => Time.now.strftime("%Y-%m-%d.1"),
  "data"    => data,
}

File.write(JSON_FILE, JSON.generate(output))
puts "build_data: wrote #{data.length} rows to #{File.expand_path(JSON_FILE)}"
